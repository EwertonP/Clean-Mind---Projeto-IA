rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function isDoctor() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidDoctor(data) {
      return data.keys().hasAll(['email', 'name', 'crp_crm', 'specialty'])
        && data.email is string && data.email.size() <= 200
        && data.name is string && data.name.size() <= 200
        && data.crp_crm is string && data.crp_crm.size() <= 100
        && data.specialty is string && data.specialty.size() <= 200
        && data.size() >= 4 && data.size() <= 8;
    }

    match /doctors/{doctorId} {
      allow get: if isSignedIn() && isValidId(doctorId) && request.auth.uid == doctorId;
      allow list: if false; 
      
      allow create: if isSignedIn() && isValidId(doctorId) && request.auth.uid == doctorId
        && isValidDoctor(incoming());
        
      allow update: if isSignedIn() && isValidId(doctorId) && request.auth.uid == doctorId
        && isValidDoctor(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'crp_crm', 'specialty', 'phone', 'cpf', 'rqe', 'plan_type']);
    }

    function isValidPatient(data) {
      return data.keys().hasAll(['doctor_id', 'name', 'email', 'phone', 'status', 'created_at'])
        && data.doctor_id is string && data.doctor_id == request.auth.uid
        && data.name is string && data.name.size() <= 200
        && data.email is string && data.email.size() <= 200
        && data.phone is string && data.phone.size() <= 50
        && data.status is string && data.status.size() <= 50
        && data.created_at is string && data.created_at.size() <= 100
        && data.size() >= 6 && data.size() <= 8;
    }

    match /patients/{patientId} {
      allow read: if isSignedIn() && isValidId(patientId) && existing().doctor_id == request.auth.uid;
      allow list: if isSignedIn() && resource.data.doctor_id == request.auth.uid;
      
      allow create: if isSignedIn() && isValidId(patientId)
        && isValidPatient(incoming());
        // For local development it's fine
        
      allow update: if isSignedIn() && isValidId(patientId) && existing().doctor_id == request.auth.uid
        && isValidPatient(incoming())
        && incoming().doctor_id == existing().doctor_id
        && incoming().created_at == existing().created_at
        && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'email', 'phone', 'health_insurance', 'status']);
        
      allow delete: if isSignedIn() && isValidId(patientId) && existing().doctor_id == request.auth.uid;
    }

    function isValidAppointment(data) {
      return data.keys().hasAll(['patient_id', 'doctor_id', 'date', 'start_time', 'duration', 'type', 'status'])
        && data.patient_id is string && data.patient_id.size() <= 128
        && data.doctor_id is string && data.doctor_id == request.auth.uid
        && data.date is string && data.date.size() <= 20
        && data.start_time is string && data.start_time.size() <= 20
        && data.duration is number
        && data.type is string && data.type.size() <= 50
        && data.status is string && data.status.size() <= 50
        && data.size() >= 7 && data.size() <= 8;
    }

    match /appointments/{appId} {
      allow read: if isSignedIn() && isValidId(appId) && existing().doctor_id == request.auth.uid;
      allow list: if isSignedIn() && resource.data.doctor_id == request.auth.uid;
      
      allow create: if isSignedIn() && isValidId(appId)
        && isValidAppointment(incoming())
        && get(/databases/$(database)/documents/patients/$(incoming().patient_id)).data.doctor_id == request.auth.uid;
        
      allow update: if isSignedIn() && isValidId(appId) && existing().doctor_id == request.auth.uid
        && isValidAppointment(incoming())
        && incoming().doctor_id == existing().doctor_id
        && incoming().patient_id == existing().patient_id
        && incoming().diff(existing()).affectedKeys().hasOnly(['date', 'start_time', 'duration', 'type', 'status']);
        
      allow delete: if isSignedIn() && isValidId(appId) && existing().doctor_id == request.auth.uid;
    }

    function isValidBilling(data) {
      return data.keys().hasAll(['patient_id', 'doctor_id', 'amount', 'due_date', 'status', 'nfe_status', 'created_at', 'auto_emit_nfe'])
        && data.patient_id is string && data.patient_id.size() <= 128
        && data.doctor_id is string && data.doctor_id == request.auth.uid
        && data.amount is number
        && data.due_date is string && data.due_date.size() <= 50
        && data.status is string && data.status.size() <= 50
        && data.nfe_status is string && data.nfe_status.size() <= 50
        && data.created_at is string && data.created_at.size() <= 100
        && data.auto_emit_nfe is bool
        && data.size() >= 8 && data.size() <= 9;
    }

    match /billing/{billId} {
      allow read: if isSignedIn() && isValidId(billId) && existing().doctor_id == request.auth.uid;
      allow list: if isSignedIn() && resource.data.doctor_id == request.auth.uid;
      
      allow create: if isSignedIn() && isValidId(billId)
        && isValidBilling(incoming())
        && get(/databases/$(database)/documents/patients/$(incoming().patient_id)).data.doctor_id == request.auth.uid;
        
      allow update: if isSignedIn() && isValidId(billId) && existing().doctor_id == request.auth.uid
        && isValidBilling(incoming())
        && incoming().doctor_id == existing().doctor_id
        && incoming().patient_id == existing().patient_id
        && incoming().created_at == existing().created_at
        && incoming().diff(existing()).affectedKeys().hasOnly(['amount', 'due_date', 'status', 'nfe_status', 'auto_emit_nfe']);
        
      allow delete: if isSignedIn() && isValidId(billId) && existing().doctor_id == request.auth.uid;
    }

    function isValidDiaryEntry(data) {
      return data.keys().hasAll(['patient_id', 'doctor_id', 'content', 'sentiment_score', 'crisis_flag', 'created_at'])
        && data.patient_id is string && data.patient_id.size() <= 128
        && data.doctor_id is string && data.doctor_id == request.auth.uid
        && data.content is string && data.content.size() <= 100000
        && data.sentiment_score is number
        && data.crisis_flag is bool
        && data.created_at is string && data.created_at.size() <= 100
        && data.size() >= 6 && data.size() <= 7;
    }

    match /diary/{diaryId} {
      allow read: if isSignedIn() && isValidId(diaryId) && existing().doctor_id == request.auth.uid;
      allow list: if isSignedIn() && resource.data.doctor_id == request.auth.uid;
      
      allow create: if isSignedIn() && isValidId(diaryId)
        && isValidDiaryEntry(incoming())
        && get(/databases/$(database)/documents/patients/$(incoming().patient_id)).data.doctor_id == request.auth.uid;
        
      allow update: if isSignedIn() && isValidId(diaryId) && existing().doctor_id == request.auth.uid
        && isValidDiaryEntry(incoming())
        && incoming().doctor_id == existing().doctor_id
        && incoming().patient_id == existing().patient_id
        && incoming().created_at == existing().created_at
        && incoming().diff(existing()).affectedKeys().hasOnly(['content', 'sentiment_score', 'crisis_flag']);
        
      allow delete: if isSignedIn() && isValidId(diaryId) && existing().doctor_id == request.auth.uid;
    }

    function isValidMedicalRecord(data) {
      return data.keys().hasAll(['patient_id', 'doctor_id', 'evolution_text', 'signature_status', 'created_at'])
        && data.patient_id is string && data.patient_id.size() <= 128
        && data.doctor_id is string && data.doctor_id == request.auth.uid
        && data.evolution_text is string && data.evolution_text.size() <= 500000
        && data.signature_status is string && data.signature_status.size() <= 50
        && data.created_at is string && data.created_at.size() <= 100
        && data.size() >= 5 && data.size() <= 8;
    }

    match /medical_records/{recordId} {
      allow read: if isSignedIn() && isValidId(recordId) && existing().doctor_id == request.auth.uid;
      allow list: if isSignedIn() && resource.data.doctor_id == request.auth.uid;
      
      allow create: if isSignedIn() && isValidId(recordId)
        && isValidMedicalRecord(incoming())
        && get(/databases/$(database)/documents/patients/$(incoming().patient_id)).data.doctor_id == request.auth.uid;
        
      allow update: if isSignedIn() && isValidId(recordId) && existing().doctor_id == request.auth.uid
        && isValidMedicalRecord(incoming())
        && incoming().doctor_id == existing().doctor_id
        && incoming().patient_id == existing().patient_id
        && incoming().created_at == existing().created_at
        && incoming().diff(existing()).affectedKeys().hasOnly(['evolution_text', 'ai_summary', 'signature_status', 'signed_at']);
        
      allow delete: if isSignedIn() && isValidId(recordId) && existing().doctor_id == request.auth.uid;
    }
  }
}
